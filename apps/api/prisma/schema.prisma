generator client {
  provider = "prisma-client-js"
}

// For Supabase: use pooled URL for DATABASE_URL (port 6543) + DIRECT_URL for migrations (port 5432).
// See apps/api/README.md — direct db.*:5432 often fails locally (IPv6 / network).
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  region       String
  role         String
  mfaSecret    String?
  mfaEnabled   Boolean  @default(false)

  agripreneur   Agripreneur?
  mentor        Mentor?
  administrator Administrator?
  payments      Payment[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agripreneur {
  id               String   @id @default(cuid())
  user             User     @relation(fields: [userId], references: [id])
  userId           String   @unique
  cropInterest     String?
  skillLevel       String?
  mentor           Mentor?  @relation("MentorToAgripreneur", fields: [mentorId], references: [id])
  mentorId         String?
  enrolledModules  LearningEnrollment[]
  aiBotSessions    AIBotSession[]
  marketplaceItems MarketplaceListing[]
  analytics        CropAnalytics[]
  badges           Badge[]
}

model Mentor {
  id                   String        @id @default(cuid())
  user                 User          @relation(fields: [userId], references: [id])
  userId               String        @unique
  expertise            String?
  cropValueChain       String?
  yearsOfExperience    Int?
  assignedAgripreneurs Agripreneur[] @relation("MentorToAgripreneur")
  sessions             AIBotSession[]
}

model Administrator {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique
}

model AIBotSession {
  id               String      @id @default(cuid())
  agripreneur      Agripreneur @relation(fields: [agripreneurId], references: [id])
  agripreneurId    String
  mentor           Mentor?     @relation(fields: [mentorId], references: [id])
  mentorId         String?
  conversationJson String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model MarketplaceListing {
  id              String      @id @default(cuid())
  owner           Agripreneur @relation(fields: [ownerId], references: [id])
  ownerId         String
  equipmentName   String
  description     String      @default("")
  condition       String
  price           Float
  transactionType String
  latitude        Float?
  longitude       Float?
  region          String      @default("NG")
  isVerified      Boolean     @default(false)
  status          String      @default("active")
  payment         Payment?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Payment {
  id          String             @id @default(cuid())
  listing     MarketplaceListing @relation(fields: [listingId], references: [id])
  listingId   String             @unique
  payer       User               @relation(fields: [payerId], references: [id])
  payerId     String
  amount      Float
  currency    String
  gateway     String
  reference   String             @unique
  status      String             @default("pending")
  gatewayRef  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model CropAnalytics {
  id                 String      @id @default(cuid())
  agripreneur        Agripreneur @relation(fields: [agripreneurId], references: [id])
  agripreneurId      String
  cropType           String
  soilHealthIndex    Float?
  historicalYield    Float?
  currentMarketPrice Float?
  region             String
  alertThreshold     Float?
  notification       Notification?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model LearningModule {
  id              String               @id @default(cuid())
  title           String
  content         String
  cropValueChain  String
  durationMinutes Int
  difficultyLevel String
  badgeName       String?
  enrollments     LearningEnrollment[]
  createdAt       DateTime             @default(now())
}

model LearningEnrollment {
  id              String         @id @default(cuid())
  agripreneur     Agripreneur    @relation(fields: [agripreneurId], references: [id])
  agripreneurId   String
  module          LearningModule @relation(fields: [moduleId], references: [id])
  moduleId        String
  progressPercent Int            @default(0)
  completed       Boolean        @default(false)
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([agripreneurId, moduleId])
}

model Badge {
  id            String      @id @default(cuid())
  agripreneur   Agripreneur @relation(fields: [agripreneurId], references: [id])
  agripreneurId String
  name          String
  description   String
  moduleId      String?
  awardedAt     DateTime    @default(now())
}

model Notification {
  id          String         @id @default(cuid())
  user        User           @relation(fields: [userId], references: [id])
  userId      String
  type        String
  content     String
  channel     String
  read        Boolean        @default(false)
  sentAt      DateTime       @default(now())
  analytics   CropAnalytics? @relation(fields: [analyticsId], references: [id])
  analyticsId String?        @unique
}
